{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["chrome-types"],
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/test/**", "vitest.config.ts", "vitest.config.integration.ts", "test/**"]
}
