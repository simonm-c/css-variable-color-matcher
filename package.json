{
  "name": "css-variable-color-matcher",
  "version": "1.0.0",
  "description": "",
  "main": "content.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "watch": "node build.mjs --watch",
    "fmt": "oxfmt --write src/**/*.ts",
    "fmt:check": "oxfmt --check src/**/*.ts",
    "lint": "oxlint src/**/*.ts",
    "lint:fix": "oxlint --fix src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "pnpm run build && vitest run --config vitest.config.integration.ts",
    "test:all": "pnpm run test && pnpm run test:integration"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonm-c/css-variable-color-matcher.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/simonm-c/css-variable-color-matcher/issues"
  },
  "homepage": "https://github.com/simonm-c/css-variable-color-matcher#readme",
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chrome-types": "^0.1.425",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
